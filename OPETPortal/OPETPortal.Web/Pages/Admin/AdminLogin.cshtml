@page "/admin/login"
@model OPETPortal.Web.Pages.Admin.AdminLoginModel
<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Admin Giriş — TALPA OPET</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'bg-base': '#0a0a0a',
                        'bg-surface': '#111111',
                        'bg-elevated': '#1a1a1a',
                        'border-subtle': 'rgba(255, 255, 255, 0.06)',
                        'border-default': 'rgba(255, 255, 255, 0.10)',
                        'text-pri': '#ededed',
                        'text-sec': '#888888',
                        'text-muted': '#555555',
                        'yellow-brand': '#f5c400',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0a0a0a; color: #ededed; }
        .glass-panel {
            background: rgba(17, 17, 17, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .animate-up {
            animation: fadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="h-full flex items-center justify-center p-6 antialiased">
    
    <!-- Background Glow -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-yellow-brand/5 blur-[120px]"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-yellow-brand/5 blur-[120px]"></div>
    </div>

    <div class="w-full max-w-[400px] animate-up">
        
        <!-- Header -->
        <div class="flex flex-col items-center mb-8">
            <div class="bg-white rounded-2xl p-3 mb-6 shadow-xl shadow-yellow-brand/5">
                <img src="/images/talpa-logo.png" alt="TALPA" class="h-10 w-auto" />
            </div>
            <h1 class="text-2xl font-extrabold text-text-pri tracking-tight">Yönetici Paneli</h1>
            <p class="text-text-sec text-sm mt-2">Güvenli giriş yaparak devam edin</p>
        </div>

        <!-- Login Card -->
        <div class="glass-panel rounded-3xl p-8 shadow-2xl relative overflow-hidden">
            <!-- Subtle accent line at top -->
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-yellow-brand/30 to-transparent"></div>

            <form method="post" class="space-y-6">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-medium rounded-xl px-4 py-3 animate-pulse">
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            @Model.ErrorMessage
                        </div>
                    </div>
                }

                <div class="space-y-1.5">
                    <label class="block text-[11px] font-bold text-text-muted uppercase tracking-widest ml-1">Kullanıcı Adı</label>
                    <div class="relative group">
                        <input name="Username" type="text" required autocomplete="username"
                               class="w-full bg-bg-elevated border border-border-default focus:border-yellow-brand/50 focus:ring-4 focus:ring-yellow-brand/5 rounded-xl px-4 py-3 text-sm text-text-pri transition-all duration-200 outline-none placeholder:text-text-muted/50"
                               placeholder="admin" />
                        <div class="absolute inset-y-0 right-4 flex items-center text-text-muted group-focus-within:text-yellow-brand transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="block text-[11px] font-bold text-text-muted uppercase tracking-widest ml-1">Şifre</label>
                    <div class="relative group">
                        <input name="Password" type="password" required autocomplete="current-password"
                               class="w-full bg-bg-elevated border border-border-default focus:border-yellow-brand/50 focus:ring-4 focus:ring-yellow-brand/5 rounded-xl px-4 py-3 text-sm text-text-pri transition-all duration-200 outline-none placeholder:text-text-muted/50"
                               placeholder="••••••••" />
                        <div class="absolute inset-y-0 right-4 flex items-center text-text-muted group-focus-within:text-yellow-brand transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                @Html.AntiForgeryToken()
                
                <button type="submit"
                        class="w-full bg-yellow-brand hover:bg-[#ffcf00] active:scale-[0.98] text-[#0a0a0a] font-bold py-3.5 rounded-xl shadow-lg shadow-yellow-brand/10 transition-all duration-200 text-sm mt-4">
                    Giriş Yap
                </button>
            </form>
        </div>

        <!-- Footer Info -->
        <p class="text-center text-text-muted text-[11px] mt-8 tracking-wide">
            &copy; @DateTime.Now.Year TALPA &mdash; TÜRKİYE HAVAYOLU PİLOTLARI DERNEĞİ
        </p>
    </div>

</body>
</html>
