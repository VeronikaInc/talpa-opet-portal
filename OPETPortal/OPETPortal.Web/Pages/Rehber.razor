@page "/rehber"
@layout MainLayout
@inject LocalizationService L

<PageTitle>@L["nav_rehber"] - TALPA OPET</PageTitle>

<section class="max-w-2xl mx-auto px-5 py-14">

    <!-- Header -->
    <div class="mb-12 animate-in">
        <h1 class="text-2xl font-bold text-text-pri mb-2">@L["guide_title"]</h1>
        <p class="text-text-sec text-sm">@L["guide_subtitle"]</p>
    </div>

    <!-- Vertical Stepper -->
    <div class="flex flex-col gap-0">

        <!-- Step 1 -->
        <div class="reveal flex gap-5">
            <div class="flex flex-col items-center">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-yellow font-bold text-sm flex-shrink-0 border"
                     style="background: rgba(245,196,0,0.10); border-color: rgba(245,196,0,0.30);">1</div>
                <div class="step-line my-1"></div>
            </div>
            <div class="flex-1 pb-8 pt-0.5">
                <div class="bg-bg-surface border border-subtle rounded-xl p-5">
                    <h3 class="font-semibold text-text-pri text-sm mb-1.5">@L["guide_step1_title"]</h3>
                    <p class="text-text-sec text-sm mb-4">@L["guide_step1_desc"]</p>
                    <div class="flex flex-wrap gap-2.5">
                        <a href="https://apps.apple.com/tr/app/otobil-mobil/id1440827450" target="_blank" rel="noopener"
                           class="btn-press inline-flex items-center gap-2 bg-bg-elevated border border-subtle hover:border-default text-text-pri px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150">
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                            </svg>
                            @L["guide_appstore"]
                        </a>
                        <a href="https://play.google.com/store/apps/details?id=com.opet.otobil" target="_blank" rel="noopener"
                           class="btn-press inline-flex items-center gap-2 bg-bg-elevated border border-subtle hover:border-default text-text-pri px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150">
                            <svg class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M3.18 23.76c.33.18.7.25 1.07.19l12.93-7.46-2.79-2.79-11.21 10.06zM.5 1.78C.2 2.1 0 2.62 0 3.3v17.4c0 .68.2 1.2.5 1.52l.08.08L9.69 13.1v-.2L.58 1.7l-.08.08zM20.12 10.4L17.1 8.65l-3.08 3.08 3.08 3.08 3.04-1.76c.87-.5.87-1.31 0-1.8l-.02.15zM4.25.05l12.93 7.46-2.79 2.79L3.18.24C3.51.08 3.92.15 4.25.05z"/>
                            </svg>
                            @L["guide_googleplay"]
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="reveal delay-75 flex gap-5">
            <div class="flex flex-col items-center">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-yellow font-bold text-sm flex-shrink-0 border"
                     style="background: rgba(245,196,0,0.10); border-color: rgba(245,196,0,0.30);">2</div>
                <div class="step-line my-1"></div>
            </div>
            <div class="flex-1 pb-8 pt-0.5">
                <div class="bg-bg-surface border border-subtle rounded-xl p-5">
                    <h3 class="font-semibold text-text-pri text-sm mb-1.5">@L["guide_step2_title"]</h3>
                    <p class="text-text-sec text-sm mb-4">@L["guide_step2_desc"]</p>
                    <a href="/sorgula"
                       class="btn-press inline-flex items-center gap-2 bg-yellow/10 border border-yellow/30 hover:border-yellow text-yellow px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        @L["guide_sorgula_link"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Step 3 -->
        <div class="reveal delay-100 flex gap-5">
            <div class="flex flex-col items-center">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-yellow font-bold text-sm flex-shrink-0 border"
                     style="background: rgba(245,196,0,0.10); border-color: rgba(245,196,0,0.30);">3</div>
                <div class="step-line my-1"></div>
            </div>
            <div class="flex-1 pb-8 pt-0.5">
                <div class="bg-bg-surface border border-subtle rounded-xl p-5">
                    <h3 class="font-semibold text-text-pri text-sm mb-1.5">@L["guide_step3_title"]</h3>
                    <p class="text-text-sec text-sm mb-3">@L["guide_step3_desc"]</p>

                    <div class="bg-bg-elevated border border-subtle rounded-lg px-4 py-3 mb-3 flex items-center gap-3">
                        <code class="font-mono text-sm text-text-pri font-semibold flex-1">@L["guide_step3_msg"]</code>
                    </div>

                    <a href="https://wa.me/904446738?text=WPOTOBILOZEL%20" target="_blank" rel="noopener"
                       class="btn-press inline-flex items-center gap-2 text-emerald-400 px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150 border"
                       style="background: rgba(34,197,94,0.08); border-color: rgba(34,197,94,0.20);">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        @L["guide_whatsapp"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Step 4 -->
        <div class="reveal delay-200 flex gap-5">
            <div class="flex flex-col items-center">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-yellow font-bold text-sm flex-shrink-0 border"
                     style="background: rgba(245,196,0,0.10); border-color: rgba(245,196,0,0.30);">4</div>
                <div class="step-line my-1"></div>
            </div>
            <div class="flex-1 pb-8 pt-0.5">
                <div class="bg-bg-surface border border-subtle rounded-xl p-5">
                    <h3 class="font-semibold text-text-pri text-sm mb-1.5">@L["guide_step4_title"]</h3>
                    <p class="text-text-sec text-sm">@L["guide_step4_desc"]</p>
                </div>
            </div>
        </div>

        <!-- Step 5 — Final -->
        <div class="reveal delay-300 flex gap-5">
            <div class="flex flex-col items-center">
                <div class="w-9 h-9 rounded-full bg-yellow flex items-center justify-center text-[#0a0a0a] font-bold text-sm flex-shrink-0">5</div>
            </div>
            <div class="flex-1 pt-0.5">
                <div class="rounded-xl p-5 border" style="background: rgba(245,196,0,0.08); border-color: rgba(245,196,0,0.22);">
                    <h3 class="font-semibold text-yellow text-sm mb-1.5">@L["guide_step5_title"]</h3>
                    <p class="text-text-sec text-sm">@L["guide_step5_desc"]</p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-12 text-center reveal">
        <a href="/sorgula"
           class="btn-press inline-flex items-center gap-2 bg-yellow text-[#0a0a0a] hover:brightness-110 font-semibold px-7 py-3 rounded-lg text-sm transition-all duration-150">
            @L["guide_sorgula_link"]
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
        </a>
    </div>

</section>
