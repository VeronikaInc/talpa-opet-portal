@page "/sss"
@layout MainLayout
@inject LocalizationService L

<PageTitle>@L["nav_sss"] - TALPA OPET</PageTitle>

<section class="max-w-2xl mx-auto px-5 py-14">

    <!-- Header -->
    <div class="mb-10 animate-in">
        <h1 class="text-2xl font-bold text-text-pri mb-2">@L["faq_title"]</h1>
        <p class="text-text-sec text-sm">Kampanya hakkında sık sorulan soruların cevapları.</p>
    </div>

    <!-- Accordion list -->
    <div class="flex flex-col gap-2">
        @foreach (var (q, a, i) in _faqs)
        {
            <details class="reveal bg-bg-surface border border-subtle rounded-xl overflow-hidden" open="@(i == 0)">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none">
                    <span class="faq-question text-sm font-medium text-text-pri pr-4">@q</span>
                    <svg class="chevron w-4 h-4 text-text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </summary>
                <div class="px-5 pb-5 pt-1 border-t border-subtle">
                    <p class="text-text-sec text-sm leading-relaxed">@a</p>
                </div>
            </details>
        }
    </div>

    <!-- Contact CTA -->
    <div class="mt-10 reveal bg-bg-elevated border border-subtle rounded-xl p-6">
        <p class="text-text-pri text-sm font-semibold mb-1">Sorunuz burada yok mu?</p>
        <p class="text-text-sec text-xs mb-4">TALPA veya OPET müşteri hizmetleri ile iletişime geçin.</p>
        <a href="tel:4446738"
           class="btn-press inline-flex items-center gap-2 bg-bg-surface border border-subtle hover:border-default text-text-sec hover:text-text-pri px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            OPET: 444 67 38
        </a>
    </div>

</section>

@code {
    private IEnumerable<(string q, string a, int i)> _faqs => new[]
    {
        (L["faq_q1"], L["faq_a1"]),
        (L["faq_q2"], L["faq_a2"]),
        (L["faq_q3"], L["faq_a3"]),
        (L["faq_q4"], L["faq_a4"]),
        (L["faq_q5"], L["faq_a5"]),
    }.Select((x, i) => (x.Item1, x.Item2, i));
}
