                    <div class="px-5 pb-5 pt-1 border-t" style="border-color: rgba(255,255,255,0.12);">
                        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.70);">@a</p>
                    </div>
                </details>
            }
        </div>

        <!-- İletişim CTA -->
        <div class="mt-10 anim rounded-xl p-6 border" style="background: var(--bg-elevated); border-color: rgba(255,255,255,0.12);">
            <p class="text-sm font-semibold mb-1" style="color: #FFFFFF;">Sorunuz burada yok mu?</p>
            <p class="text-xs mb-4" style="color: rgba(255,255,255,0.70);">TALPA veya OPET müşteri hizmetleri ile iletişime geçin.</p>
            <a href="tel:4446738"
               class="btn-press inline-flex items-center gap-2 border px-4 py-2 rounded-lg text-xs font-medium transition-colors duration-150 min-h-[40px]"
               style="background: var(--bg-surface); border-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.70);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                OPET: 444 67 38
            </a>
        </div>

    </div>
</section>

@code {
    // ── Stepper ────────────────────────────────────────────────────────
    private int _activeStep = 0;
    private System.Timers.Timer? _timer;

    private record Step(string Title, string Desc);

    private readonly Step[] _steps =
    [
        new("Uygulamayı İndir",    "Otobil Mobil'i App Store veya Google Play'den indir"),
        new("Kodunu Al",           "TC kimlik numaranla kampanya kodunu sorgula"),
        new("WhatsApp'tan Başvur", "444 67 38'e WPOTOBILOZEL [KODUN] yaz"),
        new("İndirim Aktif!",      "İlk alımdan itibaren %3 indirim otomatik uygulanır"),
    ];

    // ── Sorgula ───────────────────────────────────────────────────────
    private string _tckn = string.Empty;
    private string? _result;
    private bool _loading;
    private bool _validationError;
    private bool _copied;

    // ── SSS ───────────────────────────────────────────────────────────
    private IEnumerable<(string q, string a, int i)> _faqs =>
        new[] {
            (L["faq_q1"], L["faq_a1"]),
            (L["faq_q2"], L["faq_a2"]),
            (L["faq_q3"], L["faq_a3"]),
            (L["faq_q4"], L["faq_a4"]),
            (L["faq_q5"], L["faq_a5"]),
        }.Select((x, i) => (x.Item1, x.Item2, i));

    // ── Lifecycle ─────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        _timer = new System.Timers.Timer(3000);
        _timer.Elapsed += async (_, _) =>
        {
            _activeStep = (_activeStep + 1) % _steps.Length;
            await InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initReveal");
            await JS.InvokeVoidAsync("initScrollBehavior");
        }
    }

    public void Dispose() => _timer?.Dispose();

    // ── Sorgula methods ───────────────────────────────────────────────
    private async Task DoSorgula()
    {
        _validationError = false;
        var tckn = _tckn.Trim();
        if (tckn.Length != 11 || !tckn.All(char.IsDigit))
        {
            _validationError = true;
            return;
        }

        if (!await SistemAyarlari.BasvuruAktifMiAsync())
        {
            _result = "suspended";
            return;
        }

        var limit = await SistemAyarlari.GetMaxKodLimitiAsync();
        if (limit > 0)
        {
            var dagitilan = await SistemAyarlari.GetDagitimSayisiAsync();
            if (dagitilan >= limit)
            {
                _result = "quota_full";
                return;
            }
        }

        _loading = true;
        try
        {
            var uye = await UyeService.GetByTcknAsync(tckn);
            string logSonuc;
            if (uye == null)
            {
                _result = "not_found";
                logSonuc = "bulunamadi";
            }
            else if (uye.Borclu)
            {
                _result = "borclu";
                logSonuc = "borclu";
            }
            else
            {
                _result = uye.OpetKodu;
                logSonuc = "basarili";
                if (!uye.KodGoruntulendi)
                    await UyeService.KodGoruntulendiAsync(tckn);
            }

            var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            await UyeService.LogSorguAsync(tckn, logSonuc, ip);
        }
        finally { _loading = false; }
    }

    private async Task CopyCode()
    {
        if (_result is not null)
        {
            await JS.InvokeVoidAsync("copyToClipboard", _result);
            _copied = true;
            await Task.Delay(2000);
            _copied = false;
        }
    }

    private void Reset()
    {
        _result = null;
        _tckn = string.Empty;
        _validationError = false;
        _copied = false;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoSorgula();
    }
}
