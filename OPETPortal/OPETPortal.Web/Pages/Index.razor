        </div>

        <!-- Accordion -->
        <div class="flex flex-col gap-2">
            @foreach (var (q, a, i) in _faqs)
            {
                <details class="anim @($"anim-delay-{Math.Min(i + 1, 4)}") rounded-xl overflow-hidden border"
                         style="background: var(--bg-elevated); border-color: rgba(255,255,255,0.12);"
