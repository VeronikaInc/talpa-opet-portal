@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace OPETPortal.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TALPA OPET Otobil Mobil</title>
    <base href="~/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'bg-base':     '#1B2F5E',
                        'bg-surface':  '#243770',
                        'bg-elevated': '#2E4485',
                        'text-pri':    '#FFFFFF',
                        'text-sec':    'rgba(255,255,255,0.70)',
                        'text-muted':  'rgba(255,255,255,0.40)',
                        'navy':        '#1B2F5E',
                        'navy-dark':   '#111E3F',
                        'navy-light':  '#2A4A8A',
                        'yellow':      '#F5C400',
                        'red':         '#C8102E',
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
                    },
                    borderColor: {
                        'subtle':  'rgba(255,255,255,0.12)',
                        'default': 'rgba(255,255,255,0.18)',
                    },
                    backgroundColor: {
                        'yellow-dim': 'rgba(245,196,0,0.15)',
                    },
                }
            }
        }
    </script>
    <link href="css/site.css?v=3" rel="stylesheet" />
    <link href="OPETPortal.Web.styles.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body class="bg-bg-base text-text-pri font-sans min-h-screen antialiased">
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        Bağlantı kesildi.
        <a href="" class="font-semibold underline">Yenile</a>
        <a class="dismiss" onclick="this.parentElement.style.display='none'">✕</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script>
        // ── Clipboard ──────────────────────────────────────────────
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
        }

        // ── Dil ───────────────────────────────────────────────────
        function getLang() { return localStorage.getItem('lang') || 'tr'; }
        function setLang(lang) { localStorage.setItem('lang', lang); }

        // ── Scroll-reveal (.reveal + .anim) ───────────────────────
        window.initReveal = function () {
            const obs = new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        if (e.target.classList.contains('anim')) {
                            e.target.classList.add('animate-in');
                        } else {
                            e.target.classList.add('visible');
                        }
                        obs.unobserve(e.target);
                    }
                });
            }, { threshold: 0.08 });
            document.querySelectorAll('.reveal:not(.visible), .anim:not(.animate-in)')
                    .forEach(el => obs.observe(el));
        };

        // ── Smooth scroll + aktif nav takibi ──────────────────────
        window.initScrollBehavior = function () {
            // Smooth scroll
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });

            // Aktif section takibi
            const sections = document.querySelectorAll('section[id]');
            const navLinks  = document.querySelectorAll('nav a[href^="#"]');

            if (!sections.length || !navLinks.length) return;

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        navLinks.forEach(link => {
                            link.classList.remove('nav-active');
                            if (link.getAttribute('href') === '#' + entry.target.id) {
                                link.classList.add('nav-active');
                            }
                        });
                    }
                });
            }, { threshold: 0.4 });

            sections.forEach(s => observer.observe(s));
        };

        document.addEventListener('DOMContentLoaded', function () {
            window.initReveal();
        });
    </script>
</body>
</html>
