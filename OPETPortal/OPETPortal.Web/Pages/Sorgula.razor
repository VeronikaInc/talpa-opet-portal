@page "/sorgula"
@layout MainLayout
@inject IUyeService UyeService
@inject LocalizationService L
@inject IJSRuntime JS
@inject IHttpContextAccessor HttpContextAccessor
@inject ISistemAyarlariService SistemAyarlari

<PageTitle>@L["nav_sorgula"] - TALPA OPET</PageTitle>

<section class="min-h-[calc(100vh-7rem)] flex flex-col items-center justify-center px-5 py-12">

    <div class="w-full max-w-md">

        <!-- Header -->
        <div class="text-center mb-8 animate-in">
            <div class="inline-flex items-center gap-1.5 mb-4">
                <span class="font-semibold text-sm text-text-pri">TALPA</span>
                <span class="text-text-muted text-xs">×</span>
                <span class="font-semibold text-sm text-yellow">OPET</span>
            </div>
            <h1 class="text-2xl font-bold text-text-pri mb-2">@L["query_title"]</h1>
            <p class="text-text-sec text-sm">TC kimlik numaranızı girerek OPET kodunuza ulaşın.</p>
        </div>

        <!-- Card -->
        <div class="animate-in delay-100 bg-bg-surface border border-default rounded-xl p-7">

            @if (_result == null)
            {
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-text-sec uppercase tracking-wider mb-2">
                            @L["query_label"]
                        </label>
                        <input @bind="_tckn"
                               @onkeydown="OnKeyDown"
                               type="text"
                               maxlength="11"
                               inputmode="numeric"
                               placeholder="@L["query_placeholder"]"
                               class="input-yellow w-full bg-bg-elevated border border-default rounded-lg px-4 py-3 text-text-pri font-mono text-lg tracking-[0.2em] placeholder:text-text-muted placeholder:font-sans placeholder:tracking-normal transition-colors duration-150" />
                        @if (_validationError)
                        {
                            <p class="text-red-400 text-xs mt-2 flex items-center gap-1.5">
                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                </svg>
                                @L["query_validation"]
                            </p>
                        }
                    </div>

                    <button @onclick="DoSorgula"
                            disabled="@_loading"
                            class="btn-press w-full bg-yellow text-[#0a0a0a] disabled:opacity-40 disabled:cursor-not-allowed font-semibold py-3 rounded-lg text-sm transition-all duration-150 hover:brightness-110">
                        @if (_loading)
                        {
                            <span class="flex items-center justify-center gap-2">
                                <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                                </svg>
                                Sorgulanıyor...
                            </span>
                        }
                        else
                        {
                            @L["query_button"]
                        }
                    </button>
                </div>
            }
            else
            {
                <!-- Suspended -->
                @if (_result == "suspended")
                {
                    <div class="rounded-lg p-5 mb-5 border" style="background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.20);">
                        <div class="flex gap-3">
                            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                            </svg>
                            <div>
                                <p class="text-red-400 text-sm font-semibold mb-1">Başvuru Askıya Alındı</p>
                                <p class="text-red-400/80 text-sm">@L["query_suspended"]</p>
                            </div>
                        </div>
                    </div>
                }
                <!-- Quota full -->
                else if (_result == "quota_full")
                {
                    <div class="rounded-lg p-5 mb-5 border" style="background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.20);">
                        <div class="flex gap-3">
                            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            <div>
                                <p class="text-red-400 text-sm font-semibold mb-1">Kontenjan Doldu</p>
                                <p class="text-red-400/80 text-sm">@L["query_quota_full"]</p>
                            </div>
                        </div>
                    </div>
                }
                <!-- Not found -->
                @if (_result == "not_found")
                {
                    <div class="rounded-lg p-5 mb-5" style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.20);">
                        <div class="flex gap-3">
                            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                            <div>
                                <p class="text-red-400 text-sm font-semibold mb-1">Üyelik Bulunamadı</p>
                                <p class="text-red-400/80 text-sm">@L["query_not_found"]</p>
                            </div>
                        </div>
                    </div>
                }
                <!-- Borçlu -->
                else if (_result == "borclu")
                {
                    <div class="rounded-lg p-5 mb-5" style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.20);">
                        <div class="flex gap-3">
                            <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                            <div>
                                <p class="text-amber-400 text-sm font-semibold mb-1">Aidat Borcu Mevcut</p>
                                <p class="text-amber-400/80 text-sm">@L["query_borclu"]</p>
                            </div>
                        </div>
                    </div>
                }
                <!-- Success -->
                else
                {
                    <div class="mb-5">
                        <!-- Başarı başlığı -->
                        <div class="flex items-center gap-2 mb-4">
                            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span class="text-emerald-400 text-xs font-semibold uppercase tracking-wider">@L["query_success_label"]</span>
                        </div>

                        <!-- Kod kutusu -->
                        <div class="rounded-lg p-4 mb-4 flex items-center justify-between gap-3"
                             style="background: rgba(245,196,0,0.10); border: 1px solid rgba(245,196,0,0.22);">
                            <span class="font-mono text-2xl font-bold text-yellow tracking-[0.05em]">@_result</span>
                            <button @onclick="CopyCode"
                                    class="@(_copied ? "text-yellow border-yellow/40" : "text-text-sec hover:text-text-pri border-default hover:border-subtle") border rounded-lg px-3 py-1.5 text-xs font-medium flex items-center gap-1.5 transition-colors duration-150 flex-shrink-0 bg-bg-elevated">
                                @if (_copied)
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    @L["query_copied"]
                                }
                                else
                                {
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                    </svg>
                                    @L["query_copy"]
                                }
                            </button>
                        </div>

                        <!-- WhatsApp -->
                        <div class="bg-bg-elevated border border-subtle rounded-lg p-4 mb-4 text-center">
                            <p class="text-xs text-text-sec mb-3">@L["query_whatsapp_info"]</p>
                            <a href="https://wa.me/904446738?text=WPOTOBILOZEL%20@_result" target="_blank" rel="noopener"
                               class="btn-press inline-flex w-full justify-center items-center gap-2 bg-[#25D366] hover:bg-[#20bd5a] text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors duration-150">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                </svg>
                                @L["query_whatsapp_btn"]
                            </a>
                        </div>

                        <a href="/rehber"
                           class="btn-press block w-full text-center bg-yellow text-[#0a0a0a] hover:brightness-110 font-semibold py-2.5 rounded-lg text-sm transition-all duration-150 mb-2">
                            @L["query_guide_btn"]
                        </a>
                    </div>
                }

                <button @onclick="Reset"
                        class="btn-press w-full border border-default hover:border-subtle text-text-sec hover:text-text-pri py-2.5 rounded-lg text-sm transition-colors duration-150">
                    @L["query_new"]
                </button>
            }

        </div>
    </div>
</section>

@code {
    private string _tckn = string.Empty;
    private string? _result;
    private bool _loading;
    private bool _validationError;
    private bool _copied;

    private async Task DoSorgula()
    {
        _validationError = false;
        var tckn = _tckn.Trim();
        if (tckn.Length != 11 || !tckn.All(char.IsDigit))
        {
            _validationError = true;
            return;
        }
        // Kontrol 1: Başvuru aktif mi?
        if (!await SistemAyarlari.BasvuruAktifMiAsync())
        {
            _result = "suspended";
            return;
        }

        // Kontrol 2: Kontenjan doldu mu?
        var limit = await SistemAyarlari.GetMaxKodLimitiAsync();
        if (limit > 0)
        {
            var dagitilan = await SistemAyarlari.GetDagitimSayisiAsync();
            if (dagitilan >= limit)
            {
                _result = "quota_full";
                return;
            }
        }

        _loading = true;
        try
        {
            var uye = await UyeService.GetByTcknAsync(tckn);
            string logSonuc;
            if (uye == null)
            {
                _result = "not_found";
                logSonuc = "bulunamadi";
            }
            else if (uye.Borclu)
            {
                _result = "borclu";
                logSonuc = "borclu";
            }
            else
            {
                _result = uye.OpetKodu;
                logSonuc = "basarili";
                if (!uye.KodGoruntulendi)
                    await UyeService.KodGoruntulendiAsync(tckn);
            }

            var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            await UyeService.LogSorguAsync(tckn, logSonuc, ip);
        }
        finally { _loading = false; }
    }

    private async Task CopyCode()
    {
        if (_result is not null)
        {
            await JS.InvokeVoidAsync("copyToClipboard", _result);
            _copied = true;
            await Task.Delay(2000);
            _copied = false;
        }
    }

    private void Reset()
    {
        _result = null;
        _tckn = string.Empty;
        _validationError = false;
        _copied = false;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoSorgula();
    }
}
