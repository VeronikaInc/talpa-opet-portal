@inherits LayoutComponentBase
@inject OPETPortal.Web.Services.LocalizationService L
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="flex flex-col min-h-screen bg-bg-base">

    <!-- Navbar -->
    <header class="sticky top-0 z-50 border-b border-subtle" style="background: rgba(10,10,10,0.85); backdrop-filter: blur(12px);">
        <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between gap-4">

            <!-- Logo -->
            <a href="/" class="flex items-center group select-none">
                <!-- TALPA emblem -->
                <div class="flex items-center justify-center py-0.5" style="height:32px;">
                    <img src="images/talpa-logo.png" alt="TALPA" class="h-8 w-auto object-contain transition-transform duration-150 group-hover:scale-105" />
                </div>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden md:flex items-center gap-1">
                <NavLink href="/"        Match="NavLinkMatch.All" class="@NavCls" ActiveClass="@NavActiveAdd">@L["nav_home"]</NavLink>
                <NavLink href="/sorgula"                           class="@NavCls" ActiveClass="@NavActiveAdd">@L["nav_sorgula"]</NavLink>
                <NavLink href="/rehber"                            class="@NavCls" ActiveClass="@NavActiveAdd">@L["nav_rehber"]</NavLink>
                <NavLink href="/sss"                               class="@NavCls" ActiveClass="@NavActiveAdd">@L["nav_sss"]</NavLink>
                <div class="w-px h-4 bg-subtle mx-2"></div>
                <button @onclick="ToggleLang"
                        class="text-xs font-semibold text-text-sec hover:text-text-pri border border-default hover:border-subtle rounded-md px-2.5 py-1 transition-colors duration-150">
                    @(L.CurrentLang == "tr" ? "EN" : "TR")
                </button>
            </nav>

            <!-- Mobile right -->
            <div class="md:hidden flex items-center gap-2">
                <button @onclick="ToggleLang"
                        class="text-xs font-semibold text-text-sec border border-default rounded-md px-2.5 py-1">
                    @(L.CurrentLang == "tr" ? "EN" : "TR")
                </button>
                <button @onclick="ToggleMobileMenu"
                        class="w-8 h-8 flex items-center justify-center text-text-sec hover:text-text-pri transition-colors">
                    @if (_mobileOpen)
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    }
                </button>
            </div>
        </div>

        <!-- Mobile menu -->
        @if (_mobileOpen)
        {
            <div class="md:hidden bg-bg-surface border-t border-subtle px-5 py-3 flex flex-col gap-1">
                <a href="/"        @onclick="CloseMobile" class="@MobileNavCls">@L["nav_home"]</a>
                <a href="/sorgula" @onclick="CloseMobile" class="@MobileNavCls">@L["nav_sorgula"]</a>
                <a href="/rehber"  @onclick="CloseMobile" class="@MobileNavCls">@L["nav_rehber"]</a>
                <a href="/sss"     @onclick="CloseMobile" class="@MobileNavCls">@L["nav_sss"]</a>
            </div>
        }
    </header>

    <!-- Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="border-t border-subtle bg-bg-base">
        <div class="max-w-5xl mx-auto px-5 py-5 flex items-center justify-center text-xs text-text-muted">
            <span>© @DateTime.Now.Year TALPA — Türkiye Havayolu Pilotları Derneği</span>
        </div>
    </footer>

</div>

@code {
    private bool _mobileOpen;

    private const string NavCls       = "px-3 py-1.5 rounded-md text-sm text-text-sec hover:text-text-pri hover:bg-bg-elevated transition-colors duration-150";
    private const string NavActiveAdd = "!text-text-pri";
    private const string MobileNavCls = "px-3 py-2.5 rounded-lg text-sm text-text-sec hover:text-text-pri hover:bg-bg-elevated transition-colors";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var lang = await JS.InvokeAsync<string>("getLang");
            L.SetLang(lang ?? "tr");
            StateHasChanged();
        }
    }

    private async Task ToggleLang()
    {
        var newLang = L.CurrentLang == "tr" ? "en" : "tr";
        L.SetLang(newLang);
        await JS.InvokeVoidAsync("setLang", newLang);
        StateHasChanged();
    }

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
    private void CloseMobile() => _mobileOpen = false;
}
