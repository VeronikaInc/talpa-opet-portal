@inherits LayoutComponentBase
@inject OPETPortal.Web.Services.LocalizationService L
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="flex flex-col min-h-screen bg-bg-base">

    <!-- Navbar -->
    <header class="sticky top-0 z-50 border-b border-subtle"
            style="background: rgba(17,30,63,0.85); backdrop-filter: blur(12px);">
        <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between gap-4">

            <!-- Logo -->
            <a href="/" class="flex items-center select-none group">
                <div class="flex items-center justify-center py-0.5" style="height:32px;">
                    <img src="images/talpa-logo.png" alt="TALPA"
                         class="h-8 w-auto object-contain transition-transform duration-150 group-hover:scale-105" />
                </div>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden md:flex items-center gap-0.5">
                <a href="#sorgula" class="nav-link">@L["nav_sorgula"]</a>
                <a href="#rehber"  class="nav-link">@L["nav_rehber"]</a>
                <a href="#sss"     class="nav-link">@L["nav_sss"]</a>
                <div class="w-px h-4 mx-2" style="background: rgba(255,255,255,0.12);"></div>
                <button @onclick="ToggleLang"
                        class="text-xs font-semibold border rounded-md px-2.5 py-1 transition-colors duration-150"
                        style="color: rgba(255,255,255,0.70); border-color: rgba(255,255,255,0.18);">
                    @(L.CurrentLang == "tr" ? "EN" : "TR")
                </button>
            </nav>

            <!-- Mobile right -->
            <div class="md:hidden flex items-center gap-2">
                <button @onclick="ToggleLang"
                        class="text-xs font-semibold border rounded-md px-2.5 py-1"
                        style="color: rgba(255,255,255,0.70); border-color: rgba(255,255,255,0.18);">
                    @(L.CurrentLang == "tr" ? "EN" : "TR")
                </button>
                <button @onclick="ToggleMobileMenu"
                        class="w-8 h-8 flex items-center justify-center transition-colors"
                        style="color: rgba(255,255,255,0.70);">
                    @if (_mobileOpen)
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    }
                </button>
            </div>
        </div>

        <!-- Mobile menu -->
        @if (_mobileOpen)
        {
            <div class="md:hidden border-t border-subtle px-5 py-3 flex flex-col gap-1"
                 style="background: rgba(17,30,63,0.97);">
                <a href="#sorgula" @onclick="CloseMobile" class="@MobileNavCls">@L["nav_sorgula"]</a>
                <a href="#rehber"  @onclick="CloseMobile" class="@MobileNavCls">@L["nav_rehber"]</a>
                <a href="#sss"     @onclick="CloseMobile" class="@MobileNavCls">@L["nav_sss"]</a>
            </div>
        }
    </header>

    <!-- Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="border-t border-subtle" style="background: var(--navy-dark);">
        <div class="max-w-5xl mx-auto px-5 py-6 text-center"
             style="color: rgba(255,255,255,0.40); font-size: 0.8125rem;">
            © @DateTime.Now.Year TALPA — Türkiye Havayolu Pilotları Derneği. Tüm hakları saklıdır.
        </div>
    </footer>

</div>

@code {
    private bool _mobileOpen;

    private const string MobileNavCls = "px-3 py-2.5 rounded-lg text-sm transition-colors duration-150 block"
                                      + " text-white/70 hover:text-white hover:bg-white/5";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var lang = await JS.InvokeAsync<string>("getLang");
            L.SetLang(lang ?? "tr");
            StateHasChanged();
        }
        await JS.InvokeVoidAsync("initReveal");
    }

    private async Task ToggleLang()
    {
        var newLang = L.CurrentLang == "tr" ? "en" : "tr";
        L.SetLang(newLang);
        await JS.InvokeVoidAsync("setLang", newLang);
        StateHasChanged();
    }

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
    private void CloseMobile()       => _mobileOpen = false;
}
